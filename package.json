{
  "name": "bitwarden-to-keepass",
  "version": "1.0.0",
  "description": "Client-side web app that converts a Bitwarden/Vaultwarden export into a KeePass (.kdbx) database, entirely in the browser.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "hash-wasm": "^4.12.0",
    "kdbxweb": "^2.1.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
